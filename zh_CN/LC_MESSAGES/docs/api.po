#: ../../../../pygments/formatter.py:docstring of
#: pygments.formatter.Formatter.name:1
msgid "Full name for the formatter, in human-readable form."
msgstr ""

#: ../../../../pygments/formatter.py:docstring of
#: pygments.formatter.Formatter.aliases:1
