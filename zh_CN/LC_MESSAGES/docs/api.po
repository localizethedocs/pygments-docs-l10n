#: ../../../docs/api.rst:54
msgid "Lexers"
msgstr ""

#: ../../../docs/api.rst:56
msgid "The base lexer class from which all lexers are derived is:"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:1
msgid "Lexer for a specific language."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:3
msgid "See also :doc:`lexerdevelopment`, a high-level guide to writing lexers."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:6
msgid ""
"Lexer classes have attributes used for choosing the most appropriate lexer "
"based on various criteria."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.name:1
msgid "Full name of the lexer, in human-readable form"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.aliases:1
msgid ""
"A list of short, unique identifiers that can be used to look up the lexer "
"from a list, e.g., using `get_lexer_by_name()`."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.filenames:1
msgid ""
"A list of `fnmatch` patterns that match filenames which contain content for "
"this lexer. The patterns in this list should be unique among all lexers."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of
#: pygments.lexer.Lexer.alias_filenames:1
msgid ""
"A list of `fnmatch` patterns that match filenames which may or may not "
"contain content for this lexer. This list is used by the :func:`."
"guess_lexer_for_filename()` function, to determine which lexers are then "
"included in guessing the correct one. That means that e.g. every lexer for "
"HTML and a template language should include ``\\*.html`` in this list."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.mimetypes:1
msgid "A list of MIME types for content that can be lexed with this lexer."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.priority:1
msgid "Priority, should multiple lexers match and no content is provided"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:20
msgid "Lexers included in Pygments should have two additional attributes:"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.url:1
msgid ""
"URL of the language specification/definition. Used in the Pygments "
"documentation. Set to an empty string to disable."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of
#: pygments.lexer.Lexer.version_added:1
msgid "Version of Pygments in which the lexer was added."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:27
msgid "Lexers included in Pygments may have additional attributes:"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer._example:1
msgid ""
"Example file name. Relative to the ``tests/examplefiles`` directory. This is "
"used by the documentation generator to show an example."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:32
msgid ""
"You can pass options to the constructor. The basic options recognized by all "
"lexers and processed by the base `Lexer` class are:"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:35
msgid "``stripnl``"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:36
msgid "Strip leading and trailing newlines from the input (default: True)."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:37
msgid "``stripall``"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:38
msgid ""
"Strip all leading and trailing whitespace from the input (default: False)."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:40
msgid "``ensurenl``"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:41
msgid ""
"Make sure that the input ends with a newline (default: True).  This is "
"required for some lexers that consume input linewise."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:46
msgid "``tabsize``"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:47
msgid "If given and greater than 0, expand tabs in the input (default: 0)."
msgstr ""

#: ../../../../pygments/formatter.py:docstring of
#: pygments.formatter.Formatter:30 ../../../../pygments/lexer.py:docstring
#: pygments.lexer.Lexer:48
msgid "``encoding``"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:49
msgid ""
"If given, must be an encoding name. This encoding will be used to convert "
"the input string to Unicode, if it is not already a Unicode string (default: "
"``'guess'``, which uses a simple UTF-8 / Locale / Latin1 detection.  Can "
"also be ``'chardet'`` to use the chardet library, if it is installed."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:54
msgid "``inencoding``"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer:55
msgid "Overrides the ``encoding`` if given."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.__init__:1
msgid ""
"This constructor takes arbitrary options as keyword arguments. Every "
"subclass must first process its own options and then call the `Lexer` "
"constructor, since it processes the basic options like `stripnl`."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.__init__:6
msgid "An example looks like this:"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.__init__:8
msgid ""
"def __init__(self, **options):\n"
"    self.compress = options.get('compress', '')\n"
"    Lexer.__init__(self, **options)"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.__init__:14
msgid ""
"As these options must all be specifiable as strings (due to the command line "
"usage), there are various utility functions available to help with that, see "
"`Utilities`_."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.add_filter:1
msgid "Add a new stream filter to this lexer."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of
#: pygments.util.make_analysator.<locals>.text_analyse:1
msgid "A static method which is called for lexer guessing."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of
#: pygments.util.make_analysator.<locals>.text_analyse:3
msgid ""
"It should analyse the text and return a float in the range from ``0.0`` to "
"``1.0``.  If it returns ``0.0``, the lexer will not be selected as the most "
"probable one, if it returns ``1.0``, it will be selected immediately.  This "
"is used by `guess_lexer`."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of
#: pygments.util.make_analysator.<locals>.text_analyse:9
msgid ""
"The `LexerMeta` metaclass automatically wraps this function so that it works "
"like a static method (no ``self`` or ``cls`` parameter) and the return value "
"is automatically converted to `float`. If the return value is an object that "
"is boolean `False` it's the same as if the return values was ``0.0``."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.get_tokens:1
msgid ""
"This method is the basic interface of a lexer. It is called by the "
"`highlight()` function. It must process the text and return an iterable of "
"``(tokentype, value)`` pairs from `text`."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.Lexer.get_tokens:5
msgid ""
"Normally, you don't need to override this method. The default implementation "
"processes the options recognized by all lexers (`stripnl`, `stripall` and so "
"on), and then yields all tokens from `get_tokens_unprocessed()`, with the "
"``index`` dropped."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of
#: pygments.lexer.Lexer.get_tokens:10
msgid ""
"If `unfiltered` is set to `True`, the filtering mechanism is bypassed even "
"if filters are defined."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of
#: pygments.lexer.Lexer.get_tokens_unprocessed:1
msgid ""
"This method should process the text and return an iterable of ``(index, "
"tokentype, value)`` tuples where ``index`` is the starting position of the "
"token within the input text."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of
#: pygments.lexer.Lexer.get_tokens_unprocessed:5
msgid ""
"It must be overridden by subclasses. It is recommended to implement it as a "
"generator to maximize effectiveness."
msgstr ""

#: ../../../docs/api.rst:61
msgid ""
"There are several base class derived from ``Lexer`` you can use to build "
"your lexer from:"
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.RegexLexer:1
msgid ""
"Base for simple stateful regular expression-based lexers. Simplifies the "
"lexing process so that you need only provide a list of states and regular "
"expressions."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of
#: pygments.lexer.ExtendedRegexLexer:1
msgid "A RegexLexer that uses a context object to store its state."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.DelegatingLexer:1
msgid ""
"This lexer takes two lexer as arguments. A root lexer and a language lexer. "
"First everything is scanned using the language lexer, afterwards all "
"``Other`` tokens are lexed using the root lexer."
msgstr ""

#: ../../../../pygments/lexer.py:docstring of pygments.lexer.DelegatingLexer:6
msgid "The lexers from the ``template`` lexer package use this base lexer."
msgstr ""

